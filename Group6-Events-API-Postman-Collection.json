    {
      "name": "13. Test Without Auth (Should Fail)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/events",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "events"]
        },
        "description": "This should return 401 Unauthorized - demonstrates auth protection"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401 without auth', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Error message correct', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.contain('Unauthorized');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
