{
  "info": {
    "name": "Group 6 - Events API (Basic Auth)",
    "description": "Events Management API with HTTP Basic Authentication\n\nDefault Credentials:\n- Username: admin@example.com\n- Password: password123\n\nTotal Records: 1,111 (100 events + 1000 participants)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345678"
  },
  "item": [
    {
      "name": "1. Auth Test",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/auth-test",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "auth-test"]
        },
        "description": "Test Basic Authentication credentials"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Basic Auth successful', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql('Basic Authentication successful');",
              "    pm.expect(jsonData.auth_method).to.eql('HTTP Basic Authentication');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
