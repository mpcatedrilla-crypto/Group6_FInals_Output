  ],
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "admin@example.com",
        "type": "string"
      },
      {
        "key": "password",
        "value": "password123",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Apply Basic Auth to all requests",
          "pm.request.auth = {",
          "    type: 'basic',",
          "    basic: {",
          "        username: 'admin@example.com',",
          "        password: 'password123'",
          "    }",
          "};"
        ]
      }
    }
  ],
  "variable": [
